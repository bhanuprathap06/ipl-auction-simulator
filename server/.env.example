# Server port (Render sets this automatically)
PORT=5000

# MongoDB connection string
# Local dev:
MONGODB_URI=mongodb://localhost:27017/ipl_auction
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ipl_auction?retryWrites=true&w=majority

# Frontend URL(s) for CORS — comma-separated list for multiple origins
# Local dev:
CLIENT_URL=http://localhost:5173
# Production (Render static site URL):
# CLIENT_URL=https://ipl-auction-client.onrender.com

NODE_ENV=development
